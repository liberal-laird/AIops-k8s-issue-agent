# 调试模式
DEBUG=false

# API请求超时（秒）
TIMEOUT_SECONDS=30

# 大模型配置
# 支持的模型提供商: anthropic, openai, google, azure, deepseek, minimax, qwen
LLM_PROVIDER=qwen

# 通用大模型配置 (基于URL + API Key + 协议)
LLM_API_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_API_KEY=sk-sp-a7754c8v122112321sv
LLM_PROTOCOL=rest  # 支持: rest, grpc
LLM_API_FORMAT=openai

# 模型参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=60
LLM_MODEL=qwen3-coder-next

# 诊断配置
MAX_DIAGNOSTIC_STEPS=10
ENABLE_LOG_ANALYSIS=true
ENABLE_EVENT_ANALYSIS=true
